# Required: service session seed (32 bytes, base64url, no padding)
TRELLIS_SESSION_KEY_SEED=

# Web/OAuth
AUTH_REDIRECT=https://localhost:5173/auth/callback/github
AUTH_WEB_ORIGINS=http://localhost:5173
AUTH_PUBLIC_ORIGIN=http://localhost:5173

# NATS
NATS_SERVERS=nats
NATS_TRELLIS_CREDS_FILE=/run/trellis/creds/trellis-auth.creds
NATS_AUTH_CREDS_FILE=/run/trellis/creds/auth-auth.creds
NATS_SENTINEL_CREDS=/run/trellis/creds/sentinel.creds
NATS_AUTH_TARGET_NKEY=
NATS_AUTH_TARGET_SIGNING_SEED=
NATS_AUTH_ISSUER_NKEY=
NATS_AUTH_ISSUER_SIGNING_SEED=
NATS_AUTH_SXKEY_SEED=

# OAuth provider
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional tuning
AUTH_PORT=3000
LOG_LEVEL=info
AUTH_TTL_BINDING_TOKENS_BUCKET=7200000
AUTH_TTL_BINDING_TOKENS_INITIAL=300000
AUTH_TTL_BINDING_TOKENS_RENEW=3600000
