{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://trellis.dev/schemas/trellis.contract.v1.schema.json",
  "title": "Trellis Contract Manifest v1",
  "type": "object",
  "required": ["format", "id", "displayName", "description", "kind"],
  "properties": {
    "format": {
      "const": "trellis.contract.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "schemas": {
      "$ref": "#/$defs/schemas"
    },
    "uses": {
      "$ref": "#/$defs/uses"
    },
    "rpc": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/rpcMethod"
      }
    },
    "events": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/event"
      }
    },
    "subjects": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/subject"
      }
    },
    "errors": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/errorDecl"
      }
    },
    "resources": {
      "$ref": "#/$defs/resources"
    }
  },
  "$defs": {
    "schemaValue": {
      "type": ["object", "boolean"]
    },
    "schemaRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema"],
      "properties": {
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "schemas": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/schemaValue"
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "kv": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/kvResource"
          }
        },
        "jobs": {
          "$ref": "#/$defs/jobsResource"
        }
      }
    },
    "uses": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/useRef"
      }
    },
    "useRpc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "call": {
          "$ref": "#/$defs/capabilities"
        }
      }
    },
    "usePubSub": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "publish": {
          "$ref": "#/$defs/capabilities"
        },
        "subscribe": {
          "$ref": "#/$defs/capabilities"
        }
      }
    },
    "useRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract"],
      "properties": {
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "rpc": {
          "$ref": "#/$defs/useRpc"
        },
        "events": {
          "$ref": "#/$defs/usePubSub"
        },
        "subjects": {
          "$ref": "#/$defs/usePubSub"
        }
      }
    },
    "kvResource": {
      "type": "object",
      "required": ["purpose"],
      "additionalProperties": false,
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "history": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "ttlMs": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxValueBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "jobsResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queues"],
      "properties": {
        "queues": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/jobQueue"
          }
        }
      }
    },
    "jobQueue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload"],
      "properties": {
        "payload": {
          "$ref": "#/$defs/schemaRef"
        },
        "result": {
          "$ref": "#/$defs/schemaRef"
        },
        "maxDeliver": {
          "type": "integer",
          "minimum": 1
        },
        "backoffMs": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "ackWaitMs": {
          "type": "integer",
          "minimum": 1
        },
        "defaultDeadlineMs": {
          "type": "integer",
          "minimum": 1
        },
        "progress": {
          "type": "boolean"
        },
        "logs": {
          "type": "boolean"
        },
        "dlq": {
          "type": "boolean"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "errorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rpcMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "subject", "input", "output"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "$ref": "#/$defs/schemaRef"
        },
        "output": {
          "$ref": "#/$defs/schemaRef"
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "call": {
              "$ref": "#/$defs/capabilities"
            }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/errorRef"
          }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "subject", "event"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/.*"
          }
        },
        "event": {
          "$ref": "#/$defs/schemaRef"
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "publish": {
              "$ref": "#/$defs/capabilities"
            },
            "subscribe": {
              "$ref": "#/$defs/capabilities"
            }
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject"],
      "properties": {
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "$ref": "#/$defs/schemaRef"
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "publish": {
              "$ref": "#/$defs/capabilities"
            },
            "subscribe": {
              "$ref": "#/$defs/capabilities"
            }
          }
        }
      }
    },
    "errorDecl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "$ref": "#/$defs/schemaRef"
        }
      }
    }
  }
}
