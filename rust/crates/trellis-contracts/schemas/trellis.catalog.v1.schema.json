{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://trellis.dev/schemas/trellis.catalog.v1.schema.json",
  "title": "Trellis Deployment Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "contracts"],
  "properties": {
    "format": {
      "const": "trellis.catalog.v1"
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "digest", "displayName", "description", "kind"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
