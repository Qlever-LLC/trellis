{
  "extends": "../../deno.json",
  "name": "@qlever-llc/trellis-contracts",
  "version": "0.5.0",
  "exports": {
    ".": "./mod.ts",
    "./canonical.ts": "./canonical.ts",
    "./protocol.ts": "./protocol.ts",
    "./runtime.ts": "./runtime.ts",
    "./schema_pointers.ts": "./schema_pointers.ts"
  },
  "tasks": {
    "generate": "deno task -c ../../deno.json build:sdk",
    "generate:watch": "deno task -c ../../deno.json build:sdk",
