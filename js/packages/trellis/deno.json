{
  "extends": "../../deno.json",
  "name": "@qlever-llc/trellis",
  "version": "0.7.0",
  "exports": {
    ".": "./index.ts",
    "./auth": "./auth.ts",
    "./auth/browser": "./auth/browser.ts",
    "./browser": "./browser.ts",
    "./contracts": "./contracts.ts",
    "./server": "./server/mod.ts",
    "./server/health": "./server/health.ts",
    "./server/deno": "./server/deno.ts",
    "./server/node": "./server/node.ts",
    "./server/runtime": "./server/runtime.ts",
    "./sdk/activity": "./sdk/activity.ts",
    "./sdk/auth": "./sdk/auth.ts",
    "./sdk/core": "./sdk/core.ts",
    "./tracing": "./tracing.ts",
    "./errors": "./errors/index.ts",
    "./helpers": "./helpers.ts"
  },
  "tasks": {
    "build:npm": "deno run -A ./scripts/build_npm.ts",
    "test": "PINO_LEVEL=fatal deno test --allow-env --allow-sys --allow-write --allow-run --allow-read --allow-net",
    "test:nats": "TRELLIS_TEST_NATS=1 PINO_LEVEL=fatal deno test --allow-env --allow-sys --allow-write --allow-run --allow-read --allow-net",
    "dev": "deno run --watch main.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ],
    "verbatimModuleSyntax": true
  }
}
