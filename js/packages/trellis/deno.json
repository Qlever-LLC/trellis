{
  "extends": "../../deno.json",
  "name": "@qlever-llc/trellis-trellis",
  "version": "0.1.0",
  "exports": {
    ".": "./index.ts",
    "./browser": "./browser.ts",
    "./tracing": "./tracing.ts",
    "./contracts/*": "./contracts/*",
    "./errors": "./errors/index.ts",
    "./errors/*": "./errors/*",
    "./helpers": "./helpers.ts",
    "./helpers.ts": "./helpers.ts",
    "./models": "./models/index.ts",
    "./models/*": "./models/*"
  },
  "tasks": {
    "build:npm": "deno run -A ./scripts/build_npm.ts",
    "test": "PINO_LEVEL=fatal deno test --allow-env --allow-sys --allow-write --allow-run --allow-read --allow-net",
    "test:nats": "TRELLIS_TEST_NATS=1 PINO_LEVEL=fatal deno test --allow-env --allow-sys --allow-write --allow-run --allow-read --allow-net",
    "dev": "deno run --watch main.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ],
    "verbatimModuleSyntax": true
  }
}
