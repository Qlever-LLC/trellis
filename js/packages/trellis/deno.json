{
  "extends": "../../deno.json",
  "name": "@qlever-llc/trellis",
  "version": "0.10.13",
  "license": "Apache-2.0",
  "exports": {
    ".": "./index.ts",
    "./auth": "./auth.ts",
    "./auth/browser": "./auth/browser.ts",
    "./browser": "./browser.ts",
    "./contracts": "./contracts.ts",
    "./device": "./device.ts",
    "./device/deno": "./device/deno.ts",
    "./generate": "./generate.ts",
    "./health": "./health.ts",
    "./host": "./host/mod.ts",
    "./host/node": "./host/node.ts",
    "./jobs": "./jobs.ts",
    "./sdk/auth": "./sdk/auth.ts",
    "./sdk/core": "./sdk/core.ts",
    "./sdk/health": "./sdk/health.ts",
    "./sdk/jobs": "./sdk/jobs.ts",
    "./sdk/state": "./sdk/state.ts",
    "./service": "./service/mod.ts",
    "./service/deno": "./service/deno.ts",
    "./service/node": "./service/node.ts",
    "./telemetry": "./telemetry.ts",
    "./errors": "./errors/index.ts"
  },
  "publish": {
    "exclude": [
      ".build/**",
      "deno.npm.json",
      "import_map.npm.json",
      "npm/**",
      "scripts/**",
      "tests/**",
      "**/*_test.ts",
      "**/*.test.ts",
      "**/*.api_check.ts"
    ]
  },
  "tasks": {
    "build:npm": "deno run -A ./scripts/build_npm.ts",
    "test": "PINO_LEVEL=fatal deno test --allow-env --allow-sys --allow-write --allow-run --allow-read --allow-net",
    "dev": "deno run --watch main.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ],
    "verbatimModuleSyntax": true
  }
}
