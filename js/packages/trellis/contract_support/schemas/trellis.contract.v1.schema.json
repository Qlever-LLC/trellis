{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://trellis.dev/schemas/trellis.contract.v1.schema.json",
  "title": "Trellis Contract Manifest v1",
  "type": "object",
  "required": ["format", "id", "displayName", "description", "kind"],
  "properties": {
    "format": {
      "const": "trellis.contract.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "docs": {
      "$ref": "#/$defs/docs"
    },
    "kind": {
      "type": "string",
      "enum": ["service", "app", "device", "agent"]
    },
    "capabilities": {
      "$ref": "#/$defs/contractCapabilities"
    },
    "schemas": {
      "$ref": "#/$defs/schemas"
    },
    "exports": {
      "$ref": "#/$defs/exports"
    },
    "uses": {
      "$ref": "#/$defs/uses"
    },
    "state": {
      "$ref": "#/$defs/state"
    },
    "rpc": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/rpcMethod"
      }
    },
    "operations": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/operation"
      }
    },
    "events": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/event"
      }
    },
    "feeds": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/feed"
      }
    },
    "subjects": false,
    "errors": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/errorDecl"
      }
    },
    "jobs": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/jobQueue"
      }
    },
    "eventConsumers": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/eventConsumerGroup"
      }
    },
    "resources": {
      "$ref": "#/$defs/resources"
    }
  },
  "$defs": {
    "schemaValue": {
      "type": ["object", "boolean"]
    },
    "schemaRef": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "docs": {
      "type": "object",
      "required": ["markdown"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "markdown": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "schemas": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/schemaValue"
      }
    },
    "exports": {
      "type": "object",
      "properties": {
        "schemas": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "kv": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/kvResource"
          }
        },
        "store": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/storeResource"
          }
        }
      }
    },
    "uses": {
      "anyOf": [
        {
          "$ref": "#/$defs/usesFlat"
        },
        {
          "type": "object",
          "properties": {
            "required": {
              "$ref": "#/$defs/usesFlat"
            },
            "optional": {
              "$ref": "#/$defs/usesFlat"
            }
          }
        }
      ]
    },
    "usesFlat": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/useRef"
      }
    },
    "state": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/stateStore"
      }
    },
    "stateStore": {
      "type": "object",
      "required": ["kind", "schema"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["value", "map"]
        },
        "schema": {
          "$ref": "#/$defs/schemaRef"
        },
        "stateVersion": {
          "type": "string",
          "minLength": 1
        },
        "acceptedVersions": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/schemaRef"
          }
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "useRpc": {
      "type": "object",
      "properties": {
        "call": {
          "$ref": "#/$defs/capabilities"
        }
      }
    },
    "useOperation": {
      "type": "object",
      "properties": {
        "call": {
          "$ref": "#/$defs/capabilities"
        }
      }
    },
    "usePubSub": {
      "type": "object",
      "properties": {
        "publish": {
          "$ref": "#/$defs/capabilities"
        },
        "subscribe": {
          "$ref": "#/$defs/capabilities"
        }
      }
    },
    "useFeed": {
      "type": "object",
      "properties": {
        "subscribe": {
          "$ref": "#/$defs/capabilities"
        }
      }
    },
    "useRef": {
      "type": "object",
      "required": ["contract"],
      "properties": {
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "rpc": {
          "$ref": "#/$defs/useRpc"
        },
        "operations": {
          "$ref": "#/$defs/useOperation"
        },
        "events": {
          "$ref": "#/$defs/usePubSub"
        },
        "feeds": {
          "$ref": "#/$defs/useFeed"
        }
      }
    },
    "kvResource": {
      "type": "object",
      "required": ["purpose", "schema"],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "$ref": "#/$defs/schemaRef"
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "history": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "ttlMs": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxValueBytes": {
          "type": "integer",
          "minimum": 1
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "storeResource": {
      "type": "object",
      "required": ["purpose"],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "ttlMs": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxObjectBytes": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalBytes": {
          "type": "integer",
          "minimum": 1
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "jobKeyConcurrency": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "maxActive": {
          "type": "integer",
          "minimum": 1
        },
        "heartbeatIntervalMs": {
          "type": "integer",
          "minimum": 1
        },
        "heartbeatTtlMs": {
          "type": "integer",
          "minimum": 1
        },
        "stalePolicy": {
          "type": "string",
          "enum": ["fail-stale", "block"]
        }
      }
    },
    "jobQueueDepth": {
      "type": "object",
      "properties": {
        "maxQueuedPerKey": {
          "type": "integer",
          "minimum": 0
        },
        "whenFull": {
          "type": "string",
          "enum": ["reject", "coalesce", "replace-oldest"]
        }
      }
    },
    "jobQueue": {
      "type": "object",
      "required": ["payload"],
      "properties": {
        "payload": {
          "$ref": "#/$defs/schemaRef"
        },
        "result": {
          "$ref": "#/$defs/schemaRef"
        },
        "maxDeliver": {
          "type": "integer",
          "minimum": 1
        },
        "backoffMs": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "ackWaitMs": {
          "type": "integer",
          "minimum": 1
        },
        "defaultDeadlineMs": {
          "type": "integer",
          "minimum": 1
        },
        "progress": {
          "type": "boolean"
        },
        "logs": {
          "type": "boolean"
        },
        "dlq": {
          "type": "boolean"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "keyConcurrency": {
          "$ref": "#/$defs/jobKeyConcurrency"
        },
        "queue": {
          "$ref": "#/$defs/jobQueueDepth"
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "eventConsumerGroup": {
      "type": "object",
      "properties": {
        "uses": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "self": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "replay": {
          "type": "string",
          "enum": ["new", "all"]
        },
        "ordering": {
          "const": "strict"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "ackWaitMs": {
          "type": "integer",
          "minimum": 1
        },
        "maxDeliver": {
          "type": "integer",
          "minimum": 1
        },
        "backoffMs": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contractCapabilities": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/contractCapabilityMetadata"
      }
    },
    "contractCapabilityMetadata": {
      "type": "object",
      "required": ["displayName", "description"],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "consequence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "errorRef": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rpcMethod": {
      "type": "object",
      "required": ["version", "subject", "input", "output"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "$ref": "#/$defs/schemaRef"
        },
        "output": {
          "$ref": "#/$defs/schemaRef"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "call": {
              "$ref": "#/$defs/capabilities"
            }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/errorRef"
          }
        },
        "transfer": {
          "type": "object",
          "required": ["direction"],
          "properties": {
            "direction": {
              "const": "receive"
            }
          }
        },
        "internal": {
          "type": "boolean"
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "operation": {
      "type": "object",
      "required": ["version", "subject", "input", "output"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "$ref": "#/$defs/schemaRef"
        },
        "progress": {
          "$ref": "#/$defs/schemaRef"
        },
        "output": {
          "$ref": "#/$defs/schemaRef"
        },
        "transfer": {
          "type": "object",
          "required": ["direction", "store", "key"],
          "properties": {
            "direction": {
              "const": "send"
            },
            "store": {
              "type": "string",
              "minLength": 1
            },
            "key": {
              "type": "string",
              "pattern": "^/.*"
            },
            "contentType": {
              "type": "string",
              "pattern": "^/.*"
            },
            "metadata": {
              "type": "string",
              "pattern": "^/.*"
            },
            "expiresInMs": {
              "type": "integer",
              "minimum": 1
            },
            "maxBytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "call": {
              "$ref": "#/$defs/capabilities"
            },
            "observe": {
              "$ref": "#/$defs/capabilities"
            },
            "cancel": {
              "$ref": "#/$defs/capabilities"
            },
            "control": {
              "$ref": "#/$defs/capabilities"
            }
          }
        },
        "signals": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["input"],
            "properties": {
              "input": {
                "$ref": "#/$defs/schemaRef"
              },
              "docs": {
                "$ref": "#/$defs/docs"
              }
            }
          }
        },
        "cancel": {
          "type": "boolean"
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["version", "subject", "event"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/.*"
          }
        },
        "event": {
          "$ref": "#/$defs/schemaRef"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "publish": {
              "$ref": "#/$defs/capabilities"
            },
            "subscribe": {
              "$ref": "#/$defs/capabilities"
            }
          }
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "feed": {
      "type": "object",
      "required": ["version", "subject", "input", "event"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "$ref": "#/$defs/schemaRef"
        },
        "event": {
          "$ref": "#/$defs/schemaRef"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "subscribe": {
              "$ref": "#/$defs/capabilities"
            }
          }
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "errorDecl": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "$ref": "#/$defs/schemaRef"
        }
      }
    }
  }
}
