{
  "extends": "../../deno.json",
  "name": "@qlever-llc/trellis-sdk",
  "version": "0.7.0",
  "exports": {
    ".": "./mod.ts",
    "./activity": "./activity.ts",
    "./auth": "./auth.ts",
    "./core": "./core.ts",
    "./health": "./health.ts",
    "./jobs": "./jobs.ts",
    "./state": "./state.ts"
  },
  "tasks": {
    "build:npm": "deno run -A ./scripts/build_npm.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ],
    "verbatimModuleSyntax": true
  }
}
