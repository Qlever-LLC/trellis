{
  "extends": "../../deno.json",
  "name": "@qlever-llc/result",
  "version": "0.9.0",
  "license": "Apache-2.0",
  "exports": "./mod.ts",
  "publish": {
    "exclude": [
      "npm/**",
      "scripts/**",
      "tests/**",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  },
  "tasks": {
    "build:npm": "deno run -A ./scripts/build_npm.ts",
    "test": "deno task build:npm && deno test --allow-read"
  },
  "compilerOptions": {
    "verbatimModuleSyntax": true
  }
}
