{
  "extends": "../../deno.json",
  "name": "@qlever-llc/trellis-test",
  "version": "0.11.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./index.ts",
    "./integration": "./integration.ts",
    "./integration/runner": "./src/integration/runner.ts"
  },
  "imports": {
    "@qlever-llc/trellis": "jsr:@qlever-llc/trellis@^0.11.0",
    "@qlever-llc/trellis/auth": "jsr:@qlever-llc/trellis@^0.11.0/auth",
    "@qlever-llc/trellis/health": "jsr:@qlever-llc/trellis@^0.11.0/health",
    "@qlever-llc/trellis/sdk/auth": "jsr:@qlever-llc/trellis@^0.11.0/sdk/auth",
    "@qlever-llc/trellis/telemetry": "jsr:@qlever-llc/trellis@^0.11.0/telemetry",
    "@qlever-llc/trellis/service/deno": "jsr:@qlever-llc/trellis@^0.11.0/service/deno",
    "@nats-io/jetstream": "npm:@nats-io/jetstream@^3.3.1",
    "@nats-io/nats-core": "npm:@nats-io/nats-core@^3.3.1",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@^3.3.1",
    "@libsql/client": "npm:@libsql/client@^0.15.15",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "publish": {
    "exclude": [
      "tests/**",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  },
  "tasks": {
    "test": "deno test -A",
    "smoke:external-service-repo:serial": "deno run -A -c tests/fixtures/external-service-repo/deno.json @qlever-llc/trellis-test/integration/runner --config tests/fixtures/external-service-repo/trellis.integration.ts --case external.rpc-smoke",
    "smoke:external-service-repo:parallel": "deno run -A -c tests/fixtures/external-service-repo/deno.json @qlever-llc/trellis-test/integration/runner --config tests/fixtures/external-service-repo/trellis.integration.ts --parallel --jobs 2 --case external.rpc-smoke"
  },
  "compilerOptions": {
    "verbatimModuleSyntax": true
  }
}
