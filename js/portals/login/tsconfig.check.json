{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["npm:vite/client", "deno.ns"],
    "paths": {
      // Internal workspace-only path aliases for local source resolution.
      "@qlever-llc/trellis": ["../../packages/trellis/index.ts"],
      "@qlever-llc/trellis/auth": ["../../packages/trellis/auth.ts"],
      "@qlever-llc/trellis/auth/browser": ["../../packages/trellis/auth/browser.ts"],
      "@qlever-llc/trellis/contracts": ["../../packages/trellis/contracts.ts"],
      "@qlever-llc/trellis/server": ["../../packages/trellis/server/mod.ts"],
      "@qlever-llc/trellis/server/*": ["../../packages/trellis/server/*"],
      "@qlever-llc/trellis/sdk/auth": ["../../packages/trellis/sdk/auth.ts"],
      "@qlever-llc/trellis/sdk/core": ["../../packages/trellis/sdk/core.ts"],
      "@qlever-llc/result": ["../../packages/result/mod.ts"],
      "@qlever-llc/trellis-svelte": ["../../packages/trellis-svelte/src/index.ts"],
      "@qlever-llc/trellis-svelte/*": ["../../packages/trellis-svelte/src/*"],
      "@qlever-llc/trellis-svelte/*": ["../../packages/trellis-svelte/src/*"]
    }
  },
  "exclude": [
    "src/**/*.test.ts",
    "../../packages/server/**/*.ts",
    "../../services/**/*.ts"
  ]
}
