# Required: service session seed (32 bytes, base64url, no padding)
TRELLIS_SESSION_KEY_SEED=

# Web/OAuth
AUTH_REDIRECT=http://localhost:3000/auth/callback
AUTH_WEB_ORIGINS=http://localhost:5173,http://localhost:4173
AUTH_PUBLIC_ORIGIN=http://localhost:3000

# NATS
# Point these at your local/dev creds files.
NATS_SERVERS=localhost
NATS_TRELLIS_CREDS_FILE=.local/nats/trellis-auth.creds
NATS_AUTH_CREDS_FILE=.local/nats/auth-auth.creds
NATS_SENTINEL_CREDS=.local/nats/sentinel.creds
NATS_AUTH_TARGET_NKEY=
NATS_AUTH_TARGET_SIGNING_SEED=
NATS_AUTH_ISSUER_NKEY=
NATS_AUTH_ISSUER_SIGNING_SEED=
NATS_AUTH_SXKEY_SEED=

# OAuth provider
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional TTL tuning
AUTH_TTL_BINDING_TOKENS_BUCKET=7200000
AUTH_TTL_BINDING_TOKENS_INITIAL=300000
AUTH_TTL_BINDING_TOKENS_RENEW=3600000
