{
  "workspace": [
    "./apps/console",
    "./integration",
    "./packages/result",
    "./packages/trellis-svelte",
    "./packages/trellis-test",
    "./packages/trellis",
    "./portals/login",
    "./services/trellis"
  ],
  "tasks": {
    "contracts:verify": "deno run -A @qlever-llc/trellis/generate discover ./services/trellis",
    "prepare": "deno run -A @qlever-llc/trellis/generate prepare ..",
    "prepare:watch": "deno run -A @qlever-llc/trellis/generate prepare --watch ..",
    "packages:build:npm": "deno task -c packages/result/deno.json build:npm && deno task -c packages/trellis/deno.json build:npm && deno task -c packages/trellis-svelte/deno.json build:npm",
    "smoke:npm": "deno run -A tools/package_build/npm_smoke.ts",
    "check:npm-release": "deno task build:npm && deno task smoke:npm",
    "build:npm": "deno task prepare && deno task packages:build:npm",
    "check": "deno task prepare && deno check packages/trellis/index.ts packages/trellis-svelte/src/index.ts packages/trellis-svelte/src/context.svelte.ts packages/trellis-test/index.ts services/trellis/main.ts",
    "check:integration": "deno check -c integration/deno.json integration/runner.ts integration/matrix_conformance_test.ts integration/_support/runtime.ts integration/rpc/rpc.integration_test.ts integration/events/events.integration_test.ts integration/operations/operations.integration_test.ts integration/feeds/feeds.integration_test.ts integration/state/state.integration_test.ts integration/transfer/transfer.integration_test.ts integration/resources/resources.integration_test.ts integration/jobs/jobs.integration_test.ts integration/health/health.integration_test.ts integration/service-approval/service_approval.integration_test.ts integration/app-identity-approval/app_identity_approval.integration_test.ts integration/device-activation/device_activation.integration_test.ts",
    "fmt:integration": "deno fmt -c deno.json integration",
    "test:integration": "deno run -A -c integration/deno.json integration/runner.ts",
    "test:contracts": "deno task prepare && deno test -A packages/trellis/contract_support/source_emission_test.ts packages/trellis/contract_support/conformance_test.ts services/trellis/catalog/store.test.ts services/trellis/catalog/permissions.test.ts",
    "test:auth": "deno task prepare && deno test -A packages/trellis/auth/conformance_test.ts packages/trellis/auth/session_auth_test.ts services/trellis",
    "test:prepared:packages": "deno test -A packages/result packages/trellis packages/trellis-svelte packages/trellis-test",
    "test:prepared:service:catalog-state": "deno test -A services/trellis/bootstrap services/trellis/catalog services/trellis/contracts services/trellis/state services/trellis/storage services/trellis/config.test.ts services/trellis/manifest_conformance_test.ts services/trellis/version.test.ts",
    "test:prepared:service:auth": "deno test -A services/trellis/auth",
    "test:prepared:ui-tools": "deno test -A apps/console portals/login tools",
    "test:prepared:packaging": "deno task packages:build:npm && deno task test:prepared:packaging:built",
    "test:prepared:packaging:built": "deno test -A packages/trellis/tests/npm_artifact_smoke_test.ts packages/trellis/tests/publishing_targets_test.ts tools/package_build",
    "trellis": "bash ../scripts/trellis-cli.sh",
    "trellis-generate": "deno run -A @qlever-llc/trellis/generate"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.15",
    "@hono-rate-limiter/hono-rate-limiter": "jsr:@hono-rate-limiter/hono-rate-limiter@^0.4.2",
    "@nats-io/jetstream": "npm:@nats-io/jetstream@^3.3.1",
    "@nats-io/jwt": "npm:@nats-io/jwt@^0.0.10-5",
    "@nats-io/kv": "npm:@nats-io/kv@^3.3.1",
    "@nats-io/obj": "npm:@nats-io/obj@^3.3.1",
    "@nats-io/nkeys": "npm:@nats-io/nkeys@^2.0.3",
    "@nats-io/nats-core": "npm:@nats-io/nats-core@^3.3.1",
    "@nats-io/transport-node": "npm:@nats-io/transport-node@^3.3.1",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@^3.3.1",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-proto": "npm:@opentelemetry/exporter-metrics-otlp-proto@^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "npm:@opentelemetry/exporter-trace-otlp-proto@^0.215.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^2.7.0",
    "@opentelemetry/sdk-metrics": "npm:@opentelemetry/sdk-metrics@^2.7.0",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@^2.7.0",
    "@opentelemetry/sdk-trace-node": "npm:@opentelemetry/sdk-trace-node@^2.7.0",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@^1.40.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.29/parse-args",
    "@std/collections": "jsr:@std/collections@^1.1.7",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@standard-schema/spec": "npm:@standard-schema/spec@^1.1.0",
    "@sveltejs/acorn-typescript": "npm:@sveltejs/acorn-typescript@^1.0.9",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^7.0.1",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@3.0.10",
    "@sveltejs/kit": "npm:@sveltejs/kit@2.58.0",
    "@sveltejs/kit/": "./node_modules/@sveltejs/kit/",
    "@sveltejs/kit/internal": "./node_modules/@sveltejs/kit/src/exports/internal/index.js",
    "@sveltejs/kit/internal/server": "./node_modules/@sveltejs/kit/src/exports/internal/server.js",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@2.58.0/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@7.0.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.2.4",
    "@types/cookie": "npm:@types/cookie@^1.0.0",
    "@types/node": "npm:@types/node@25.6.0",
    "#trellis-generated-sdk/auth": "./../generated/packages/jsr/auth/mod.ts",
    "#trellis-generated-sdk/core": "./../generated/packages/jsr/trellis-core/mod.ts",
    "#trellis-generated-sdk/health": "./../generated/packages/jsr/health/mod.ts",
    "#trellis-generated-sdk/jobs": "./../generated/packages/jsr/jobs/mod.ts",
    "#trellis-generated-sdk/state": "./../generated/packages/jsr/state/mod.ts",
    "acorn": "npm:acorn@^8.16.0",
    "clsx": "npm:clsx@2.1.1",
    "cookie": "npm:cookie@^1.1.1",
    "daisyui": "npm:daisyui@5.5.19/index.js",
    "devalue": "npm:devalue@^5.7.1",
    "drizzle-orm": "npm:drizzle-orm@0.44.7",
    "esm-env": "npm:esm-env@^1.2.2",
    "json-schema-library": "npm:json-schema-library@^11.4.0",
    "js-sha256": "npm:js-sha256@^0.11.1",
    "jsonc-parser": "npm:jsonc-parser@^3.3.1",
    "graphology": "npm:graphology@^0.26.0",
    "graphology-layout-forceatlas2": "npm:graphology-layout-forceatlas2@^0.10.1",
    "kleur": "npm:kleur@^4.1.5",
    "magic-string": "npm:magic-string@^0.30.21",
    "mrmime": "npm:mrmime@^2.0.1",
    "oauth4webapi": "npm:oauth4webapi@^3.8.5",
    "openid-client": "npm:openid-client@^6.8.3",
    "pino": "npm:pino@^10.3.1",
    "serialize-error": "npm:serialize-error@^13.0.1",
    "set-cookie-parser": "npm:set-cookie-parser@^3.1.0",
    "sigma": "npm:sigma@^3.0.2",
    "sirv": "npm:sirv@^3.0.2",
    "svelte": "npm:svelte@5.55.5",
    "svelte-check": "npm:svelte-check@4.4.6",
    "tailwindcss": "npm:tailwindcss@4.2.4",
    "tweetnacl": "npm:tweetnacl@^1.0.3",
    "ts-deepmerge": "npm:ts-deepmerge@^7.0.3",
    "type-fest": "npm:type-fest@^5.6.0",
    "typebox": "npm:typebox@^1.1.33",
    "typescript": "npm:typescript@6.0.3",
    "ulid": "npm:ulid@^3.0.2",
    "vite": "npm:vite@8.0.10",
    "zod": "npm:zod@^4.3.6"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ],
    "verbatimModuleSyntax": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "import-map-remap"
      ]
    }
  }
}
