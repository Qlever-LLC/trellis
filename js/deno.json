{
  "workspace": [
    "./apps/activity",
    "./apps/trellis",
    "./packages/auth",
    "./packages/contracts",
    "./packages/telemetry",
    "./packages/result",
    "./packages/server",
    "./packages/trellis-svelte",
    "./packages/trellis",
    "./portals/login",
    "./workloads/demo",
    "./services/activity",
    "./services/jobs",
    "./services/trellis"
  ],
  "tasks": {
    "contracts:verify": "deno task -c services/trellis/deno.json verify:contracts",
    "services:build:sdk": "deno task --recursive --filter @qlever-llc/trellis-service-* build:sdk",
    "build:sdk": "deno task services:build:sdk",
    "packages:build:npm": "deno task -c packages/result/deno.json build:npm && deno task -c packages/trellis/deno.json build:npm && deno task -c packages/trellis-svelte/deno.json build:npm",
    "generated:build:npm": "bash -lc 'cd ../generated/js/sdks/auth && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts && cd ../trellis-core && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts && cd ../activity && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts'",
    "build:npm": "deno task build:sdk && deno task packages:build:npm",
    "check": "deno task build:sdk && deno check packages/trellis/index.ts packages/trellis-svelte/src/context.svelte.ts packages/trellis-svelte/src/state/auth.svelte.ts packages/trellis-svelte/src/state/nats.svelte.ts packages/trellis-svelte/src/state/trellis.svelte.ts services/trellis/main.ts",
    "test:contracts": "deno task build:sdk && deno test -A packages/contracts/source_emission_test.ts packages/contracts/conformance_test.ts services/trellis/catalog/store.test.ts services/trellis/catalog/permissions.test.ts",
    "test:auth": "deno task build:sdk && deno test -A packages/auth/conformance_test.ts packages/auth/session_auth_test.ts services/trellis",
    "trellis": "bash ../scripts/trellis-cli.sh"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.9.8",
    "@hono-rate-limiter/hono-rate-limiter": "jsr:@hono-rate-limiter/hono-rate-limiter@^0.4.2",
    "@nats-io/jetstream": "npm:@nats-io/jetstream@^3.3.0",
    "@nats-io/jwt": "npm:@nats-io/jwt@^0.0.10-5",
    "@nats-io/kv": "npm:@nats-io/kv@^3.2.0",
    "@nats-io/nkeys": "npm:@nats-io/nkeys@^2.0.3",
    "@nats-io/nats-core": "npm:@nats-io/nats-core@^3.3.1",
    "@nats-io/transport-node": "npm:@nats-io/transport-node@^3.3.1",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@^3.2.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "npm:@opentelemetry/exporter-trace-otlp-http@^0.56.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^1.29.0",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@^1.29.0",
    "@opentelemetry/sdk-trace-node": "npm:@opentelemetry/sdk-trace-node@^1.29.0",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@^1.28.0",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.14/parse-args",
    "@std/collections": "jsr:@std/collections@^1.1.3",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@deno/dnt": "jsr:@deno/dnt@^0.41.3",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^4.0.0",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.8",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@^2.48.3/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.2.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.17",
    // Internal workspace-only aliases for local source resolution and generated SDK builds.
    "@qlever-llc/trellis-auth": "./packages/auth/mod.ts",
    "@qlever-llc/trellis-contracts": "./packages/contracts/mod.ts",
    "@qlever-llc/result": "./packages/result/mod.ts",
    "@qlever-llc/trellis-server": "./packages/server/mod.ts",
    "@qlever-llc/trellis-telemetry": "./packages/telemetry/mod.ts",
    "@qlever-llc/trellis-sdk-activity": "../generated/js/sdks/activity/mod.ts",
    "@qlever-llc/trellis-svelte": "./packages/trellis-svelte/src/index.ts",
    "@qlever-llc/trellis-sdk-auth": "../generated/js/sdks/auth/mod.ts",
    "@qlever-llc/trellis-sdk-core": "../generated/js/sdks/trellis-core/mod.ts",
    "@qlever-llc/trellis-jobs": "./packages/jobs/mod.ts",
    "@qlever-llc/trellis": "./packages/trellis/index.ts",
    "@qlever-llc/trellis/auth": "./packages/trellis/auth.ts",
    "@qlever-llc/trellis/auth/browser": "./packages/trellis/auth/browser.ts",
    "@qlever-llc/trellis/browser": "./packages/trellis/browser.ts",
    "@qlever-llc/trellis/contracts": "./packages/trellis/contracts.ts",
    "@qlever-llc/trellis/server": "./packages/trellis/server/mod.ts",
    "@qlever-llc/trellis/server/health": "./packages/trellis/server/health.ts",
    "@qlever-llc/trellis/server/deno": "./packages/trellis/server/deno.ts",
    "@qlever-llc/trellis/server/node": "./packages/trellis/server/node.ts",
    "@qlever-llc/trellis/server/runtime": "./packages/trellis/server/runtime.ts",
    "@qlever-llc/trellis/sdk/activity": "./packages/trellis/sdk/activity.ts",
    "@qlever-llc/trellis/sdk/auth": "./packages/trellis/sdk/auth.ts",
    "@qlever-llc/trellis/sdk/core": "./packages/trellis/sdk/core.ts",
    "@qlever-llc/trellis/tracing": "./packages/trellis/tracing.ts",
    "json-schema-library": "npm:json-schema-library@^10.5.2",
    "jsonc-parser": "npm:jsonc-parser@^3.3.1",
    "oauth4webapi": "npm:oauth4webapi@^3.8.1",
    "openid-client": "npm:openid-client@^6.8.0",
    "pino": "npm:pino@^9.11.0",
    "serialize-error": "npm:serialize-error@^12.0.0",
    "svelte": "npm:svelte@5.46.0",
    "ts-deepmerge": "npm:ts-deepmerge@^7.0.3",
    "type-fest": "npm:type-fest@^5.0.1",
    "typebox": "npm:typebox@^1.0.15",
    "ulid": "npm:ulid@^3.0.1",
    "zod": "npm:zod@^4.1.11"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "verbatimModuleSyntax": true
  },
  "lint": {
    "rules": {
      "exclude": ["import-map-remap"]
    }
  }
}
