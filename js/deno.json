{
  "workspace": [
    "./apps/console",
    "./packages/result",
    "./packages/trellis-sdk",
    "./packages/trellis-svelte",
    "./packages/trellis",
    "./portals/login",
    "./services/activity",
    "./services/trellis"
  ],
  "tasks": {
    "contracts:verify": "cargo run --manifest-path ../rust/tools/generate/Cargo.toml --bin trellis-generate -- discover ./services/trellis",
    "prepare": "cargo run --manifest-path ../rust/tools/generate/Cargo.toml --bin trellis-generate -- prepare ..",
    "release:bump-base": "deno run -A tools/release/bump_checked_in_versions.ts",
    "packages:build:npm": "deno task -c packages/result/deno.json build:npm && deno task -c packages/trellis-sdk/deno.json build:npm && deno task -c packages/trellis/deno.json build:npm && deno task -c packages/trellis-svelte/deno.json build:npm",
    "generated:build:npm": "bash -lc 'cd ../generated/js/sdks/auth && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts && cd ../trellis-core && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts && cd ../activity && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts && cd ../health && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts && cd ../state && deno run --config ../../../../js/deno.json -A ./scripts/build_npm.ts'",
    "build:npm": "deno task prepare && deno task packages:build:npm",
    "check": "deno task prepare && deno check packages/trellis/index.ts packages/trellis-svelte/src/index.ts packages/trellis-svelte/src/context.svelte.ts services/trellis/main.ts",
    "test:contracts": "deno task prepare && deno test -A packages/trellis/contract_support/source_emission_test.ts packages/trellis/contract_support/conformance_test.ts services/trellis/catalog/store.test.ts services/trellis/catalog/permissions.test.ts",
    "test:auth": "deno task prepare && deno test -A packages/trellis/auth/conformance_test.ts packages/trellis/auth/session_auth_test.ts services/trellis",
    "trellis": "bash ../scripts/trellis-cli.sh",
    "trellis-generate": "cargo run --manifest-path ../rust/tools/generate/Cargo.toml --bin trellis-generate --"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.9.8",
    "@hono-rate-limiter/hono-rate-limiter": "jsr:@hono-rate-limiter/hono-rate-limiter@^0.4.2",
    "@nats-io/jetstream": "npm:@nats-io/jetstream@^3.3.0",
    "@nats-io/jwt": "npm:@nats-io/jwt@^0.0.10-5",
    "@nats-io/kv": "npm:@nats-io/kv@^3.2.0",
    "@nats-io/obj": "npm:@nats-io/obj@^3.3.1",
    "@nats-io/nkeys": "npm:@nats-io/nkeys@^2.0.3",
    "@nats-io/nats-core": "npm:@nats-io/nats-core@^3.3.1",
    "@nats-io/transport-node": "npm:@nats-io/transport-node@^3.3.1",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@^3.2.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "npm:@opentelemetry/exporter-trace-otlp-proto@^0.56.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^1.29.0",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@^1.29.0",
    "@opentelemetry/sdk-trace-node": "npm:@opentelemetry/sdk-trace-node@^1.29.0",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@^1.28.0",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.14/parse-args",
    "@std/collections": "jsr:@std/collections@^1.1.3",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@deno/dnt": "jsr:@deno/dnt@^0.41.3",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^4.0.0",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.8",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@^2.48.3/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.2.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.17",
    // Internal workspace-only aliases for local source resolution and generated SDK builds.
    "@qlever-llc/result": "./packages/result/mod.ts",
    "@qlever-llc/trellis-svelte": "./packages/trellis-svelte/src/index.ts",
    "@qlever-llc/trellis": "./packages/trellis/index.ts",
    "@qlever-llc/trellis/auth": "./packages/trellis/auth.ts",
    "@qlever-llc/trellis/auth/browser": "./packages/trellis/auth/browser.ts",
    "@qlever-llc/trellis/browser": "./packages/trellis/browser.ts",
    "@qlever-llc/trellis/contracts": "./packages/trellis/contracts.ts",
    "@qlever-llc/trellis/device": "./packages/trellis/device.ts",
    "@qlever-llc/trellis/device/deno": "./packages/trellis/device/deno.ts",
    "@qlever-llc/trellis/health": "./packages/trellis/health.ts",
    "@qlever-llc/trellis/service": "./packages/trellis/service/mod.ts",
    "@qlever-llc/trellis/service/deno": "./packages/trellis/service/deno.ts",
    "@qlever-llc/trellis/service/node": "./packages/trellis/service/node.ts",
    "@qlever-llc/trellis/jobs": "./packages/trellis/jobs.ts",
    "@qlever-llc/trellis/host": "./packages/trellis/host/mod.ts",
    "@qlever-llc/trellis/host/deno": "./packages/trellis/host/deno.ts",
    "@qlever-llc/trellis/host/node": "./packages/trellis/host/node.ts",
    "@qlever-llc/trellis-sdk": "./packages/trellis-sdk/mod.ts",
    "@qlever-llc/trellis-sdk/jobs": "./packages/trellis-sdk/jobs.ts",
    "@qlever-llc/trellis-sdk/activity": "./packages/trellis-sdk/activity.ts",
    "@qlever-llc/trellis-sdk/auth": "./packages/trellis-sdk/auth.ts",
    "@qlever-llc/trellis-sdk/core": "./packages/trellis-sdk/core.ts",
    "@qlever-llc/trellis-sdk/health": "./packages/trellis-sdk/health.ts",
    "@qlever-llc/trellis-sdk/state": "./packages/trellis-sdk/state.ts",
    "@qlever-llc/trellis/tracing": "./packages/trellis/tracing.ts",
    "json-schema-library": "npm:json-schema-library@^10.5.2",
    "js-sha256": "npm:js-sha256@^0.11.1",
    "jsonc-parser": "npm:jsonc-parser@^3.3.1",
    "oauth4webapi": "npm:oauth4webapi@^3.8.1",
    "openid-client": "npm:openid-client@^6.8.0",
    "pino": "npm:pino@^9.11.0",
    "serialize-error": "npm:serialize-error@^12.0.0",
    "svelte": "npm:svelte@5.46.0",
    "tweetnacl": "npm:tweetnacl@^1.0.3",
    "ts-deepmerge": "npm:ts-deepmerge@^7.0.3",
    "type-fest": "npm:type-fest@^5.0.1",
    "typebox": "npm:typebox@^1.0.15",
    "ulid": "npm:ulid@^3.0.1",
    "zod": "npm:zod@^4.1.11"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "verbatimModuleSyntax": true
  },
  "lint": {
    "rules": {
      "exclude": ["import-map-remap"]
    }
  }
}
