FROM docker.io/denoland/deno:2.7.7 AS build

WORKDIR /app

COPY js /app/js
COPY generated/js /app/generated/js

WORKDIR /app/js/apps/trellis

RUN deno run -A npm:vite build

FROM docker.io/library/nginx:1.29-alpine

COPY js/apps/trellis/nginx.conf /etc/nginx/conf.d/default.conf
COPY js/apps/trellis/docker-entrypoint.d/40-runtime-config.sh /docker-entrypoint.d/40-runtime-config.sh
COPY --from=build /app/js/apps/trellis/build /usr/share/nginx/html

RUN chmod +x /docker-entrypoint.d/40-runtime-config.sh

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
