{
  "name": "@trellis-demo/app",
  "version": "0.0.0",
  "exports": "./contract.ts",
  "links": [
    "../../js/packages/result",
    "../../js/packages/trellis",
    "../../js/packages/trellis-svelte"
  ],
  "tasks": {
    "prepare": "cargo run --manifest-path ../../rust/tools/generate/Cargo.toml --bin trellis-generate -- prepare ..",
    "dev": "deno task prepare && deno run -A vite dev",
    "build": "deno task prepare && deno run -A vite build",
    "preview": "deno run -A vite preview",
    "check": "deno task prepare && deno task check:prepared",
    "check:prepared": "deno run -A @sveltejs/kit sync && deno run -A svelte-check --tsconfig ./tsconfig.check.json"
  },
  "imports": {
    "@qlever-llc/result": "../../js/packages/result/mod.ts",
    "@qlever-llc/trellis-svelte": "../../js/packages/trellis-svelte/src/index.ts",
    "@qlever-llc/trellis": "../../js/packages/trellis/index.ts",
    "@qlever-llc/trellis/auth": "../../js/packages/trellis/auth.ts",
    "@qlever-llc/trellis/auth/browser": "../../js/packages/trellis/auth/browser.ts",
    "@qlever-llc/trellis/browser": "../../js/packages/trellis/browser.ts",
    "@qlever-llc/trellis/contracts": "../../js/packages/trellis/contracts.ts",
    "@qlever-llc/trellis/device/deno": "../../js/packages/trellis/device/deno.ts",
    "@qlever-llc/trellis/errors": "../../js/packages/trellis/errors/index.ts",
    "@qlever-llc/trellis/service": "../../js/packages/trellis/service/mod.ts",
    "@qlever-llc/trellis/service/deno": "../../js/packages/trellis/service/deno.ts",
    "@qlever-llc/trellis/sdk/auth": "../../generated/packages/jsr/auth/mod.ts",
    "@qlever-llc/trellis/sdk/core": "../../generated/packages/jsr/trellis-core/mod.ts",
    "@qlever-llc/trellis/sdk/health": "../../generated/packages/jsr/health/mod.ts",
    "@qlever-llc/trellis/sdk/jobs": "../../generated/packages/jsr/jobs/mod.ts",
    "@qlever-llc/trellis/sdk/state": "../../generated/packages/jsr/state/mod.ts",
    "@trellis-sdk/trellis-demo-service": "../js/generated/packages/jsr/demo-service/mod.ts",
    "@sveltejs/acorn-typescript": "npm:@sveltejs/acorn-typescript@^1.0.9",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^7.0.1",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@3.0.10",
    "@sveltejs/kit": "npm:@sveltejs/kit@2.58.0",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@2.58.0/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@7.0.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.2.4",
    "@types/node": "npm:@types/node@25.6.0",
    "clsx": "npm:clsx@2.1.1",
    "daisyui": "npm:daisyui@5.5.19/index.js",
    "devalue": "npm:devalue@^5.7.1",
    "esm-env": "npm:esm-env@^1.2.2",
    "kleur": "npm:kleur@^4.1.5",
    "magic-string": "npm:magic-string@^0.30.21",
    "mrmime": "npm:mrmime@^2.0.1",
    "sirv": "npm:sirv@^3.0.2",
    "svelte": "npm:svelte@5.55.5",
    "svelte-check": "npm:svelte-check@4.4.6",
    "tailwindcss": "npm:tailwindcss@4.2.4",
    "typebox": "npm:typebox@^1.0.15",
    "typescript": "npm:typescript@6.0.3",
    "vite": "npm:vite@8.0.10"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "verbatimModuleSyntax": true,
    "types": [
      "npm:vite/client"
    ]
  }
}
