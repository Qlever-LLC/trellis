{
  "extends": "../../js/deno.json",
  "links": [
    "../../js/packages/result",
    "../../js/packages/trellis",
    "../../js/packages/trellis-svelte"
  ],
  "workspace": ["./service", "./device", "./app"],
  "tasks": {
    "prepare": "cargo run --manifest-path ../../rust/tools/generate/Cargo.toml --bin trellis-generate -- prepare ..",
    "prepare:watch": "cargo run --manifest-path ../../rust/tools/generate/Cargo.toml --bin trellis-generate -- prepare --watch ..",
    "check": "deno task prepare && deno task check:service && deno task check:device && deno task check:app",
    "check:service": "deno task -c service/deno.json check:prepared",
    "check:device": "deno task -c device/deno.json check:prepared",
    "check:app": "deno task -c app/deno.json check:prepared",
    "service": "deno task -c service/deno.json start",
    "device": "deno task -c device/deno.json start",
    "app": "deno task -c app/deno.json dev"
  },
  "imports": {
    "@trellis-sdk/trellis-demo-service": "./generated/js/sdks/demo-service/mod.ts",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.1",
    "@hono/hono": "jsr:@hono/hono@^4.9.8",
    "@hono-rate-limiter/hono-rate-limiter": "jsr:@hono-rate-limiter/hono-rate-limiter@^0.4.2",
    "@libs/qrcode": "jsr:@libs/qrcode@^3.0.1",
    "@nats-io/jetstream": "npm:@nats-io/jetstream@^3.3.0",
    "@nats-io/jwt": "npm:@nats-io/jwt@^0.0.10-5",
    "@nats-io/kv": "npm:@nats-io/kv@^3.2.0",
    "@nats-io/nats-core": "npm:@nats-io/nats-core@^3.3.1",
    "@nats-io/nkeys": "npm:@nats-io/nkeys@^2.0.3",
    "@nats-io/obj": "npm:@nats-io/obj@^3.3.1",
    "@nats-io/transport-node": "npm:@nats-io/transport-node@^3.3.1",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@^3.2.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "npm:@opentelemetry/exporter-trace-otlp-proto@^0.215.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^2.7.0",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@^2.7.0",
    "@opentelemetry/sdk-trace-node": "npm:@opentelemetry/sdk-trace-node@^2.7.0",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@^1.40.0",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.14/parse-args",
    "@std/collections": "jsr:@std/collections@^1.1.3",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@deno/dnt": "jsr:@deno/dnt@^0.41.3",
    "@standard-schema/spec": "npm:@standard-schema/spec@^1.1.0",
    "@sveltejs/acorn-typescript": "npm:@sveltejs/acorn-typescript@^1.0.9",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^7.0.1",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@3.0.10",
    "@sveltejs/kit": "npm:@sveltejs/kit@2.58.0",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@2.58.0/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@7.0.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.2.4",
    "@types/cookie": "npm:@types/cookie@^1.0.0",
    "@types/node": "npm:@types/node@25.6.0",
    "acorn": "npm:acorn@^8.16.0",
    "chalk": "npm:chalk@^5.6.2",
    "clsx": "npm:clsx@2.1.1",
    "cookie": "npm:cookie@^1.1.1",
    "daisyui": "npm:daisyui@5.5.19/index.js",
    "devalue": "npm:devalue@^5.7.1",
    "esm-env": "npm:esm-env@^1.2.2",
    "json-schema-library": "npm:json-schema-library@^10.5.2",
    "js-sha256": "npm:js-sha256@^0.11.1",
    "jsonc-parser": "npm:jsonc-parser@^3.3.1",
    "kleur": "npm:kleur@^4.1.5",
    "magic-string": "npm:magic-string@^0.30.21",
    "mrmime": "npm:mrmime@^2.0.1",
    "oauth4webapi": "npm:oauth4webapi@^3.8.1",
    "openid-client": "npm:openid-client@^6.8.0",
    "pino": "npm:pino@^9.11.0",
    "serialize-error": "npm:serialize-error@^12.0.0",
    "set-cookie-parser": "npm:set-cookie-parser@^3.1.0",
    "sirv": "npm:sirv@^3.0.2",
    "svelte": "npm:svelte@5.55.5",
    "svelte-check": "npm:svelte-check@4.4.6",
    "tailwindcss": "npm:tailwindcss@4.2.4",
    "tweetnacl": "npm:tweetnacl@^1.0.3",
    "ts-deepmerge": "npm:ts-deepmerge@^7.0.3",
    "type-fest": "npm:type-fest@^5.0.1",
    "typebox": "npm:typebox@^1.0.15",
    "typescript": "npm:typescript@6.0.3",
    "ulid": "npm:ulid@^3.0.1",
    "vite": "npm:vite@8.0.10",
    "zod": "npm:zod@^4.1.11"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "verbatimModuleSyntax": true
  }
}
