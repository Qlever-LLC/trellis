{
  "extends": "../../js/deno.json",
  "links": [
    "../../js/packages/result",
    "../../js/packages/trellis",
    "../../js/packages/trellis-svelte"
  ],
  "workspace": [
    "./rpc/service",
    "./rpc/device",
    "./operation/service",
    "./operation/device",
    "./transfer/service",
    "./transfer/device",
    "./kv/service",
    "./kv/device",
    "./jobs/service",
    "./jobs/device",
    "./state/device",
    "./app"
  ],
  "tasks": {
    "prepare": "cargo run --manifest-path ../../rust/tools/generate/Cargo.toml --bin trellis-generate -- prepare ..",
    "prepare:watch": "cargo run --manifest-path ../../rust/tools/generate/Cargo.toml --bin trellis-generate -- prepare --watch ..",
    "check": "deno task prepare && deno task check:service:rpc && deno task check:device:rpc && deno task check:service:operation && deno task check:device:operation && deno task check:service:transfer && deno task check:device:transfer && deno task check:service:kv && deno task check:device:kv && deno task check:service:jobs && deno task check:device:jobs && deno task check:device:state && deno task check:app",
    "check:service:rpc": "deno task -c rpc/service/deno.json check:prepared",
    "check:device:rpc": "deno task -c rpc/device/deno.json check:prepared",
    "check:service:operation": "deno task -c operation/service/deno.json check:prepared",
    "check:device:operation": "deno task -c operation/device/deno.json check:prepared",
    "check:service:transfer": "deno task -c transfer/service/deno.json check:prepared",
    "check:device:transfer": "deno task -c transfer/device/deno.json check:prepared",
    "check:service:kv": "deno task -c kv/service/deno.json check:prepared",
    "check:device:kv": "deno task -c kv/device/deno.json check:prepared",
    "check:service:jobs": "deno task -c jobs/service/deno.json check:prepared",
    "check:device:jobs": "deno task -c jobs/device/deno.json check:prepared",
    "check:device:state": "deno task -c state/device/deno.json check:prepared",
    "check:app": "deno task -c app/deno.json check:prepared",
    "service:rpc": "deno task -c rpc/service/deno.json start",
    "device:rpc": "deno task -c rpc/device/deno.json start",
    "service:operation": "deno task -c operation/service/deno.json start",
    "device:operation": "deno task -c operation/device/deno.json start",
    "service:transfer": "deno task -c transfer/service/deno.json start",
    "device:transfer": "deno task -c transfer/device/deno.json start",
    "service:kv": "deno task -c kv/service/deno.json start",
    "device:kv": "deno task -c kv/device/deno.json start",
    "service:jobs": "deno task -c jobs/service/deno.json start",
    "device:jobs": "deno task -c jobs/device/deno.json start",
    "device:state": "deno task -c state/device/deno.json start",
    "app": "deno task -c app/deno.json dev"
  },
