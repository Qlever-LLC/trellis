{
  "extends": "../../deno.json",
  "name": "@trellis-demo/jobs-device",
  "version": "0.0.0",
  "exports": "./src/main.ts",
  "tasks": {
    "prepare": "deno task -c ../../deno.json prepare",
    "check": "deno task prepare && deno task check:prepared",
    "check:prepared": "deno check src/main.ts contract.ts",
    "start": "deno run --allow-env --allow-net --allow-read --allow-write --allow-sys src/main.ts"
  }
}
